# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token-here

# Data Source API Keys (all free tiers)
CENSUS_API_KEY=your-census-api-key         # register at api.census.gov/data/key_signup.html
BLS_API_KEY=your-bls-api-key               # register at www.bls.gov/developers/api_signature_v2.htm
BEA_API_KEY=your-bea-api-key               # register at apps.bea.gov/api/signup
FRED_API_KEY=your-fred-api-key             # register at fred.stlouisfed.org/docs/api/api_key.html

# Internal API protection
INTERNAL_API_SECRET=generate-a-random-secret-here

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=The Watchtower

# Optional: Email (Phase 2 - Alerts)
# RESEND_API_KEY=re_your-resend-key-here
